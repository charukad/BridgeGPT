# Server Configuration
PORT=3000
HOST=0.0.0.0

# API Authentication
# Generate a strong key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=change-me-to-a-strong-key

# Browser Configuration
HEADLESS=false
BROWSER_TIMEOUT=60000

# ChatGPT Configuration
CHATGPT_URL=https://chatgpt.com

# Cache Configuration
CACHE_ENABLED=false
CACHE_TTL_SECONDS=3600

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAY_MS=2000

# Logging
LOG_LEVEL=info
LOG_REQUESTS=true

# ── v2 Configuration ──

# Conversation Memory (Feature 15)
# Max number of prior messages to pass as history context
MAX_HISTORY_MESSAGES=20
